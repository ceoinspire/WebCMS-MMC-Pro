@using Microsoft.VisualStudio.Web.CodeGenerators.Mvc.Templates.BlazorIdentity.Pages.Manage
@model PagesViewModel

@{
	ViewBag.Title = "All Purpose CMS System";
	Layout = "~/Views/Shared/_Layout.cshtml";
}


<!-- Page header -->
<div class="page-header page-header-light">
	<div class="page-header-content header-elements-md-inline">
		<div class="page-title d-flex">
			<h4><i class="icon-arrow-left52 mr-2"></i> <span class="font-weight-semibold">Mailbox</span></h4>
			<a href="#" class="header-elements-toggle text-default d-md-none"><i class="icon-more"></i></a>
		</div>


	</div>

	<div class="breadcrumb-line breadcrumb-line-light header-elements-md-inline">
		<div class="d-flex">
			<div class="breadcrumb">
				<a href="/" class="breadcrumb-item"><i class="icon-home2 mr-2"></i> Dashboard</a>
				<span class="breadcrumb-item active">Inbox</span>
			</div>

			<a href="#" class="header-elements-toggle text-default d-md-none"><i class="icon-more"></i></a>
		</div>


	</div>
</div>
<!-- /page header -->
<!-- Content area -->
<div class="content">

	<div class="d-md-flex align-items-md-start">
		<partial name="/Views/CmsEmail/_CMSEmailSideMenu.cshtml" />
		<div class="flex-fill overflow-auto">
			<div id="" class="card">


				<div class="bg-light">
					<div class="navbar navbar-light bg-light navbar-expand-lg py-lg-2">
						

						<div class="navbar-collapse text-center text-lg-left flex-wrap collapse" id="inbox-toolbar-toggle-multiple">
							<div class="mt-3 mt-lg-0">
								<div class="btn-group">
									<input type="checkbox" class="mainselectChkbox" />

								
								</div>

								<div class="btn-group ml-3 mr-lg-3">
									<button type="button" class="btn btn-light"><i class="icon-pencil7"></i> <span class="d-none d-lg-inline-block ml-2">Compose</span></button>
									<button id="btn-delete" type="button" class="btn btn-light"><i class="icon-bin"></i> <span class="d-none d-lg-inline-block ml-2">Delete</span></button>
									<div type="button" class="btn btn-light">Total: <span id="emailCounter" style="padding:10px;" class="badge bg-success badge-pill ml-auto">count</span></div>
								</div>
							</div>

							<div class="navbar-text ml-lg-auto">
								<div>
									<select id="pageSize" class="form-control">
										<option value="10">10</option>
										<option value="20">20</option>
										<option value="30">30</option>
										<option value="50">50</option>

									</select>
								</div>
							</div>

							<div class="ml-lg-3 mb-3 mb-lg-0">


								<form action="#">
									<div class="form-group form-group-feedback form-group-feedback-right">
										<input id="searchQuery" type="search" class="form-control wmin-200" placeholder="Search messages" />
										<div class="form-control-feedback">
											<i class="icon-search4 font-size-base text-muted"></i>
										</div>
									</div>
								</form>


							</div>
						</div>
					</div>
				</div>
				<div class="table-responsive">
					<table class="table table-inbox">
						<tbody id="emailList" data-link="row" class="rowlink">
							@* <partial name="/Views/CmsEmail/_PartialEmails.cshtml" /> *@
						
						</tbody>
					</table>
					<div class="col-lg-12">

						<div id="paginationControls">
							<!-- Pagination will be appended here -->
						</div>
					</div>

				</div>

				


			</div>





		</div>
	</div>
</div>
@section jq {
}

<script>

	$(document).ready(function () {
		let searchTimeout;
		fetchEmails(1);
		$('#searchQuery').on('keyup', function () {
			const query = $(this).val().trim();

			clearTimeout(searchTimeout);

			if (query.length >= 3 || query.length === 0) {

				searchTimeout = setTimeout(function () {
					fetchEmails();
				}, 500);
			}
		})
		$('#pageSize').on('change', function () {
			fetchEmails();
		});
	});
	
	var currentPage = 1;

	function fetchEmails(pageNumber = currentPage) {
		
		currentPage = pageNumber;
		var pageSize = $('#pageSize').val();
		var searchQuery = $('#searchQuery').val();
		var orderBy = "EmailId";
		
		$.get('/CMSEmail/PartialEmails', {
			websiteId: 1, 
			pageNumber: currentPage,
			pageSize: pageSize,
			searchQuery: searchQuery,
			orderBy: orderBy
		}, function (data) {
			
			console.log(data.res);
			$('#emailList').html('');
			$('#emailCounter').text(data.res.emailCount)
			$.each(data.res.emails, function (index, email) {
		
				
				
				var rowHtml = '<tr class="unread">' +
					'<td class="table-inbox-checkbox rowlink-skip">' +
					'<input type="checkbox" class="listchkboxes" data-value="' + email.emailId + '" />' +
					'</td>' +
					'<td class="table-inbox-star rowlink-skip">' +
					'<a href="#"><i class="icon-star-empty3 text-muted"></i></a>' +
					'</td>' +
					'<td class="table-inbox-image">' +
					'<img src="/global_assets/images/placeholders/user.png" class="rounded-circle" width="32" height="32" alt="">' +
					'</td>' +
					'<td class="table-inbox-name">' +
					'<a href="/cmsemail/inbox/folder/' + email.emailId + '">' +
					'<div class="letter-icon-title text-default">' +
					((email.fullName && email.fullName.trim() !== '') ? email.fullName : 'Anonymous') +
					'</div>' +
					'</a>' +
					'</td>' +
					'<td class="table-inbox-message">' +
					'<div class="table-inbox-subject">' + email.emailSubject + '</div>' +
					'' +
					'</td>' +
										'<td class="table-inbox-time">' + Utility.getFormattedDate(email.dateCreated) +
					'</td>' +
					'</tr>';

				// Append the row to the table
				$('#emailList').append(rowHtml);
			});
			updatePagination(data.res.totalPages);
		});
	}

	function updatePagination(totalPages) {
		let paginationHtml = '';
		for (let i = 1; i <= totalPages; i++) {
			const activeClass = (i === currentPage) ? 'active' : '';
			paginationHtml += `<li class="page-item ${activeClass}"><a href="#" class="page-link" data-page="${i}">${i}</a></li>`;
		}
		paginationHtml += `
			<li class="page-item">
				<a href="#" class="page-link" data-page="${currentPage + 1}">Next &rarr;</a>
			</li>`;

		$('#paginationControls').html(`<ul class="pagination  pagination-flat pagination-rounded align-self-center">${paginationHtml}</ul>`);

		// Bind click event to pagination links
		$('.page-link').on('click', function (e) {
			e.preventDefault();
			var page = $(this).data('page');
			if (page !== currentPage && page > 0 && page <= totalPages) {
				fetchEmails(page);
			}
		});
	}



	var emailList = [];
	function GetSelectedEmailList() {
		$('.listchkboxes:checked').each(function () {
			
			emailList = [];
			var EmailId = $(this).data('value');
			emailList.push({ 'EmailId': EmailId });
		});
		return emailList;
	}
	$('#btn-delete').click(function () {

		
		var emails = GetSelectedEmailList();
		var formData = {
			Emails: emails
		}

		$('#confirmDialog').dialog({
			resizable: false,
			height: "auto",
			width: 400,
			modal: true,
			buttons: {
				"Yes": function () {
					// Action for Yes
					$('.loader-wrapper').show();
					
					$.ajax({
						url: '/CmsEmail/DeleteEmails',
						method: 'POST',
						data: formData,
						success: function (e) {
							if (e['statusCode'] === '200') {
								setTimeout(function () {
									$('.alert-success').css('display', 'block');
									setTimeout(function () {
										$('.alert-success').css('display', 'none');
										$('.loader-wrapper').hide();
									}, 1500)
								}, 0)
								location.reload(); S
							}
							else {
								setTimeout(function () {
									$('.alert-danger').css('display', 'block');
									setTimeout(function () {
										$('.alert-danger').css('display', 'none');
										$('.loader-wrapper').hide();

									}, 1500)
								}, 0)
							}
						}
					})
					$(this).dialog("close");
				},
				"No": function () {
					// Action for No
					alert("You chose No!");
					$(this).dialog("close");
				}
			}
		});
















	
	});













	$(document).ready(function () {

		$('.mainselectChkbox').on('click', function () {
			
			if ($(this).prop('checked')) {
				$('.listchkboxes').prop('checked', true);
			} else {
				$('.listchkboxes').prop('checked', false);
			}
		});

	
	});

	

</script>