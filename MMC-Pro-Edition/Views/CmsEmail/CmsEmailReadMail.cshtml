							</div>
						</li>
					</ul>
						-->
				</div>
				<!-- /attachments -->

			</div>
			<!-- /single mail -->

		</div>
		<!-- /right content -->

	</div>
	<!-- /inner container -->

</div>
<!-- /content area -->
