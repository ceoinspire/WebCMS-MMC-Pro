										<ul class="list-inline list-inline-condensed mb-0">
											<li class="list-inline-item text-muted">736 KB</li>
											<li class="list-inline-item"><a href="#">View</a></li>
											<li class="list-inline-item"><a href="#">Download</a></li>
										</ul>
