@model PagesViewModel
@{
	Layout = null;
}
<table class="table table-hover table-striped table-responsive-lg">
	<thead class="table-info bg-indigo">
		<tr>
			<th>Content Title</th>
			<th>Content Type</th>
			<th>Meta Title</th>
			<th>Created On</th>

			<th>Status</th>
			<th class="text-center" style="width: 30px;"><i class="icon-menu-open2"></i></th>
		</tr>
	</thead>
	<tbody>
		@foreach (var item in Model.Emails.OrderByDescending(x => x.DateCreated))
		{
			<tr>
				<td>
					<strong>@item.EmailSender</strong>
				</td>
				<td>
					<span class="badge badge-info">@item.EmailSubject</span>

				</td>
				<td>@item?.IsSend</td>
				<td>@item?.DateCreated</td>
			

				<td>
					@if (Convert.ToBoolean(item.IsSend))
					{
						<span class="badge badge-success">Active</span>

					}
					else
					{
						<span class="badge badge-danger">Not Send</span>

					}
				</td>
				<td class="text-center">
					<div class="list-icons">
						<div class="dropdown">
							<a href="#" class="list-icons-item" data-toggle="dropdown">
								<i class="icon-menu9"></i>
							</a>
							<div class="dropdown-menu dropdown-menu-right">
								<a href="#" class="dropdown-item"><i class="icon-database-edit2"></i> View Body</a>
								<a href="#" class="remove dropdown-item"><i class="icon-mail-read"></i> Re Send</a>
								<a href="#" class="dropdown-item"><i class="icon-file-remove"></i> Delete</a>
							</div>
						
						</div>
					</div>
				</td>
			</tr>
		}


	</tbody>
</table>




<div id="bottom-right" class="">
	<div class="alert alert-success alert-styled-right alert-arrow-right alert-dismissible" style="display:none">
		<button id="contentSubmit" type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
		<span class="font-weight-semibold">Well done!</span> Data Updated Successfully
	</div>
</div>
<div id="bottom-right">
	<div class="alert alert-danger alert-styled-right alert-dismissible" style="display:none">
		<button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
		<span class="font-weight-semibold">Oh snap!</span> Change a few things up and <a href="#" class="alert-link">try submitting again</a>.
	</div>
</div>

<style>
	#bottom-right {
		position: fixed;
		bottom: 20px; /* You can adjust this value to change the vertical position */
		right: 20px; /* You can adjust this value to change the horizontal position */
	}

</style>