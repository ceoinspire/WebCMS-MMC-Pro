@using System.Text.Json
@using MMC_Pro_Edition.Repository


<div class="navbar-brand">
	<a href="index.html" class="d-inline-block">
		<img src="global_assets/images/logo_dark.png" alt="">
	</a>
</div>

<div class="d-md-none">
	<button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbar-mobile">
		<i class="icon-tree5"></i>
	</button>
	<button class="navbar-toggler sidebar-mobile-main-toggle" type="button">
		<i class="icon-paragraph-justify3"></i>
	</button>
</div>

<div class="collapse navbar-collapse" id="navbar-mobile">
	<ul class="navbar-nav">
		<li class="nav-item">
			<a href="#" class="navbar-nav-link sidebar-control sidebar-main-toggle d-none d-md-block">
				<i class="icon-paragraph-justify3"></i>
			</a>
		</li>
	</ul>
	 
	@{
		byte[]? userarray = Context.Session.Get("LoginUser");
		if (userarray == null)
		{

			Context.Response.Redirect("/Accounts/Logout");
			return;
		}
		var us = JsonSerializer.Deserialize<MMC_Pro_Edition.ViewModel.LoginVM>(userarray);
	}
	<span class="navbar-text ml-md-3">
		<span class="badge badge-mark border-orange-300 mr-2"></span>
		 @MMC_Pro_Edition.ViewModel.TimeHelper.GetGreeting(), @us?.Person?.FirstName  @us?.Person?.LastName!
	</span>

	<ul class="navbar-nav ml-md-auto">
		<li class="nav-item dropdown">
			<a href="#" class="navbar-nav-link  dropdown-toggle" data-toggle="dropdown">
				<i class="icon-make-group mr-2"></i>
				Applications
			</a>

			<div class="dropdown-menu dropdown-menu-right dropdown-content wmin-md-350">
				<div class="dropdown-content-body p-2">
					<div class="row no-gutters">
						<div class="col-12 col-sm-4">
							@if (PagesViewModel.Settings.Where(x => x.ApplicationId == 1001).Any())
							{
								var cmssetting = PagesViewModel.Settings.Where(x => x.ApplicationId == 1001).FirstOrDefault();
								<a href="@AppHelper.CreateSSOURL(1001)" class="d-block text-default text-center ripple-dark rounded p-3">
									<i class="icon-diff-added text-blue-400 icon-2x"></i>
									<div class="font-size-sm font-weight-semibold text-uppercase mt-2">@cmssetting.ApplicationName</div>
								</a>
							}
							@if (PagesViewModel.Settings.Where(x => x.ApplicationId == 1003).Any())
							{
								var websetupsetting = PagesViewModel.Settings.Where(x => x.ApplicationId == 1003).FirstOrDefault();
								<a href="@AppHelper.CreateSSOURL(1003)" class="d-block text-default text-center ripple-dark rounded p-3">
									<i class="icon-versions icon-2x"></i>
									<div class="font-size-sm font-weight-semibold text-uppercase mt-2">@websetupsetting.ApplicationName</div>
								</a>

							}
						


						</div>
						<div class="col-12 col-sm-4">
							<a href="/WebsiteSetup/SetupAdmin" class="d-block text-default text-center ripple-dark rounded p-3">
								<i class="icon-versions icon-2x"></i>
								<div class="font-size-sm font-weight-semibold text-uppercase mt-2">WebSetup</div>
							</a>

							
						</div>
						<div class="col-12 col-sm-4">

							@if (PagesViewModel.Settings.Where(x => x.ApplicationId == 1002).Any())
							{
								var marketsetting = PagesViewModel.Settings.Where(x => x.ApplicationId == 1002).FirstOrDefault();
								<a href="@AppHelper.CreateSSOURL(1002)" class="d-block text-default text-center ripple-dark rounded p-3">
									<i class="icon-store text-pink-400 icon-2x"></i>
									<div class="font-size-sm font-weight-semibold text-uppercase mt-2">@marketsetting?.ApplicationName</div>
								</a>

							}
							@if (PagesViewModel.Settings.Where(x => x.ApplicationId == 1004).Any())
							{
								var setting = PagesViewModel.Settings.Where(x => x.ApplicationId == 1004).FirstOrDefault();
								<a href="@AppHelper.CreateSSOURL(1004)" class="d-block text-default text-center ripple-dark rounded p-3">
									<i class="icon-store2 text-success-400 icon-2x"></i>
									<div class="font-size-sm font-weight-semibold text-uppercase mt-2">@setting.ApplicationName</div>
								</a>

							}


						</div>

					</div>
				</div>
			</div>
		</li>

