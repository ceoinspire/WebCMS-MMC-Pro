
@model PagesViewModel

<form id="addnew-contenttype" action="/Action/Controler" method="post">
	<div class="form-group">
		<div class="row">
			<div class="col-sm-12">
				<label>Content Heading</label>
				<input id="contentType" type="text" placeholder="Content Type" class="form-control">
			</div>
		</div>
	</div>
	<div class="form-group">
		<div class="row">
			<div class="col-sm-12">
				<button id="cTypesubmit" class="btn bg-success form-control"> Create Content Type</button>
			</div>
		</div>
	</div>
</form>




<script type="text/javascript">
	$('#addnew-contenttype').submit(function (e) {
		e.preventDefault();
		var formData = {
			cTitle: $('#contentType').val(),
		}
		//$('#cTypesubmit').html('Loading....');
		$.ajax({
			url: "/Content/CreateContentType/",
			method: "POST",
			data: formData,
			success: function (result) {
				debugger;
				if (result["statusCode"] === "200") {
					setTimeout(function () {
						$('.alert-success').css('display', 'block');
						$('#cTypesubmit').html("Loading....");
						setTimeout(function () {
							$('#cTypesubmit').html('Submit');
							$('.alert-success').css('display', 'none');
							location.reload();

						}, 3000)
					}, 1000)

				}
				else {
					setTimeout(function () {
						$('.alert-danger').css('display', 'block');
						$('#cTypesubmit').html("Loading....");
						setTimeout(function () {
							$('#cTypesubmit').html('Submit');
							$('.alert-danger').css('display', 'none');
						}, 3000)
					}, 1000)
				}
			}
		});

	});


</script>