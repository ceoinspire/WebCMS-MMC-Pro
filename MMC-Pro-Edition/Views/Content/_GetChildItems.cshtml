@model PagesViewModel
<div class="card shadow">
	<div class="card-body">
		<div class="col-10">
		</div>
		<div class="col-2">
			<a id="addchildContent" href="#" class="btn btn-success">Add New</a>

		</div>

	</div>
</div>


<div class="card shadow">
	<div class="card-body">
		<table class="table table-hover table-striped table-responsive-lg">
			<thead class="table-danger">
				<tr>
					<th>Content Title</th>
					<th>Content Type</th>
					<th>Meta Title</th>
					<th>Created On</th>

					<th>Status</th>
					<th class="text-center" style="width: 30px;"><i class="icon-menu-open2"></i></th>
				</tr>
			</thead>
			<tbody>
				@foreach (var item in Model.ContentTypeSlugs)
				{
					<tr>
						<td>
							<a target="_blank" href="/Content/EditContent/@item.Id">
								<strong>@item.Name</strong>
							</a>
						</td>
						<td>
							<span class="badge badge-info">@item.ContentTypeVM.Name</span>

						</td>
						<td>@item?.MetaTitle</td>
						<td>@item.CreatedOn</td>

						<td>
							<span class="badge badge-success">Active</span>
						</td>
						<td class="text-center">
							<div class="list-icons">
								<div class="dropdown">
									<a href="#" class="list-icons-item" data-toggle="dropdown">
										<i class="icon-menu9"></i>
									</a>

									<div class="dropdown-menu dropdown-menu-right">
										<a target="_blank" href="/Content/EditContent/@item.Id" class="dropdown-item"><i class="icon-database-edit2"></i> Edit</a>
										<a href="/Content/DeleteContent/@item.Id" class="remove dropdown-item"><i class="icon-database-remove"></i> Delete</a>
									</div>
								</div>
							</div>
						</td>
					</tr>
				}


			</tbody>
		</table>

	</div>
</div>




<script type="text/javascript">
	$('#addchildContent').click(function () {
		debugger;
		$.ajax({
			url: "/Content/AddChildContent/" + @Model.ContentId,
			type: "POST",
			success: function (data) {
				$('.modal-title').html('Add Child Item');
				$('.modal-body').html(data);
				$('#modal_theme_success').modal();
			}
		})
	})
</script>