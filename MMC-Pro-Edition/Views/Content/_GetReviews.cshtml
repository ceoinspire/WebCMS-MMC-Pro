@model PagesViewModel


<div class="card shadow">
	<div class="card-body">
		<table class="table table-hover table-striped table-responsive-lg">
			<thead class="table-success bg-indigo">
				<tr>
					<th>Publish / Unpublish</th>
					<th>Comments</th>
					<th>Rating</th>
					<th>Created On</th>

					<th>Status</th>
					<th class="text-center" style="width: 30px;"><i class="icon-menu-open2"></i></th>
				</tr>
			</thead>
			<tbody>
				@foreach (var item in Model.Reviews)
				{
					<tr>
						<td>
							<strong>@item.IsPublished</strong>
						</td>
						<td>
							<span class="badge badge-info">@item.Comment</span>

						</td>
						<td>@item?.Rating</td>
						<td>@item.CreatedOn</td>

						<td>
							<span class="badge badge-success">Active</span>
						</td>
						<td class="text-center">
							<div class="list-icons">
								<div class="dropdown">
									<a href="#" class="list-icons-item" data-toggle="dropdown">
										<i class="icon-menu9"></i>
									</a>

									<div class="dropdown-menu dropdown-menu-right">
										<a href="/Content/EditContent/@item.ReviewId" class="dropdown-item"><i class="icon-database-edit2"></i> Edit</a>
										<a href="/Content/DeleteContent/@item.ReviewId" class="remove dropdown-item"><i class="icon-database-remove"></i> Delete</a>
										<a href="#" class="dropdown-item"><i class="icon-file-word"></i> Export to .doc</a>
									</div>
								</div>
							</div>
						</td>
					</tr>
				}


			</tbody>
		</table>

	</div>
</div>






<script type="text/javascript">
	$('#addchildContent').click(function () {
		debugger;
		$.ajax({
			url: "/Content/AddChildContent/" + @Model.ContentId,
			type: "POST",
			success: function (data) {
				$('.modal-title').html('Add Child Item');
				$('.modal-body').html(data);
				$('#modal_theme_success').modal();
			}
		})
	})
</script>