
@model PagesViewModel

<table class="table table-hover table-striped table-responsive-lg">
	<thead class="table-info bg-indigo">
		<tr>
			<th>Content Title</th>
			<th>Content Type</th>
			<th>Meta Title</th>
			<th>Created On</th>

			<th>Status</th>
			<th class="text-center" style="width: 30px;"><i class="icon-menu-open2"></i></th>
		</tr>
	</thead>
	<tbody>
		@foreach (var item in Model.ContentTypeSlugs.OrderByDescending(x=>x.Id))
		{
			<tr>
				<td>
					<a  href="/Content/EditContent/@item.Id">
						<strong style="color:black">@item.Name</strong>
					</a>
				
				</td>
				<td>
					<span class="badge badge-info">@item.ContentTypeVM?.Name</span>

				</td>
				<td>@item?.MetaTitle</td>
				<td>@item.CreatedOn</td>

				<td>
					<span class="badge badge-success">Active</span>
				</td>
				<td class="text-center">
					<div class="list-icons">
						<div class="dropdown">
							<a href="#" class="list-icons-item" data-toggle="dropdown">
								<i class="icon-menu9"></i>
							</a>

							<div class="dropdown-menu dropdown-menu-right">
								<a href="/Content/EditContent/@item.Id" class="dropdown-item"><i class="icon-database-edit2"></i> Edit</a>
								<a  href="/Content/DeleteContent/@item.Id" class="remove dropdown-item"><i class="icon-database-remove"></i> Delete</a>
							</div>
						</div>
					</div>
				</td>
			</tr>
		}


	</tbody>
</table>




<div id="bottom-right" class="">
	<div class="alert alert-success alert-styled-right alert-arrow-right alert-dismissible" style="display:none">
		<button id="contentSubmit" type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
		<span class="font-weight-semibold">Well done!</span> Data Updated Successfully
	</div>
</div>
<div id="bottom-right">
	<div class="alert alert-danger alert-styled-right alert-dismissible" style="display:none">
		<button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
		<span class="font-weight-semibold">Oh snap!</span> Change a few things up and <a href="#" class="alert-link">try submitting again</a>.
	</div>
</div>

<style>
	#bottom-right {
		position: fixed;
		bottom: 20px; /* You can adjust this value to change the vertical position */
		right: 20px; /* You can adjust this value to change the horizontal position */
	}

</style>
<script>
	$('.table-hover').dataTable();
	$('#itemcount').html('Total Content: ' + @Model.ContentTypeSlugs.Count);

	$('.remove').click(function (e) {
		e.preventDefault();
		var link = $(this).attr('href');
		$.ajax({
			url:link,
			type:'POST',
			success: function (result) {
				if (result['statusCode'] === "200") {
					setTimeout(function () {
						$('.alert-success').css('display', 'block');
						setTimeout(function () {
							$('.alert-success').css('display', 'none');

						}, 2000)
					}, 1000)
					location.reload();
				}
				else{
					setTimeout(function () {
						$('.alert-danger').css('display', 'block');
						setTimeout(function () {
							$('.alert-danger').css('display', 'none');

						}, 2000)
					}, 1000)
				}
			}
		})
	})

</script>